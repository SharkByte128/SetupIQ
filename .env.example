# ── Database ───────────────────────────────────────────────
POSTGRES_PASSWORD=setupiq
POSTGRES_PORT=5432

# ── API ────────────────────────────────────────────────────
API_PORT=3001
JWT_SECRET=change-me-to-a-random-32-char-string
CORS_ORIGIN=https://dev.setupiq.app

# ── OAuth2 (optional — app works without auth) ────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── AI / LLM (optional) ───────────────────────────────────
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=

# ── Web ────────────────────────────────────────────────────
# Empty = same-origin (Caddy proxies /api/* and /auth/* to API)
VITE_API_URL=

# ── Caddy / TLS ────────────────────────────────────────────
SITE_DOMAIN=dev.setupiq.app
# Cloudflare API token with Zone:DNS:Edit permission for your domain
CLOUDFLARE_API_TOKEN=
